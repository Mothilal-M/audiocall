# ---- Audiocall — VM config ----
# Copy to .env.production on the VM and fill in. NEVER commit the real file.
#   cp .env.production.example .env.production
#   docker compose --env-file .env.production up -d --build

# Subdomain (DNS A record) pointing at the VM. Used for routing, Let's Encrypt,
# and as SERVER_HOST so Twilio's TwiML points back at wss://<domain>/stream.
DOMAIN=audio-call.10xscale.ai
# Email Let's Encrypt uses for expiry notices (reuse the same one).
LETSENCRYPT_EMAIL=you@10xscale.ai

# --- Google AI (Gemini Live API via AI Studio) ---
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=
AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# --- Twilio (from https://console.twilio.com) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+15551234567
