# ──────────────────────────────────────────────────────────────────────────────
# Google AI / ADK
# ──────────────────────────────────────────────────────────────────────────────

# Choose ONE platform:

# --- Option A: Gemini Live API (Google AI Studio) — free, great for development
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_google_api_key_here

# --- Option B: Vertex AI Live API (Google Cloud) — enterprise, for production
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# Model to use (native audio, recommended)
# Gemini Live API:   gemini-2.5-flash-native-audio-preview-12-2025
# Vertex AI Live API: gemini-live-2.5-flash-native-audio
AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# ──────────────────────────────────────────────────────────────────────────────
# Twilio
# ──────────────────────────────────────────────────────────────────────────────
# Find these in the Twilio Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# ──────────────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────────────
# Public hostname that Twilio can reach (no scheme, no trailing slash).
# For local development, use ngrok: ngrok http 8000  → copy the *.ngrok.io host
# Example: SERVER_HOST=big-apples-burn.loca.lt   ← NO https:// prefix!
SERVER_HOST=your_public_hostname_here

# Set to "false" for local HTTP/WS development (e.g., plain ngrok tunnels)
USE_TLS=true

# Port the uvicorn server listens on
PORT=8000

# Set to any non-empty value to enable uvicorn auto-reload (dev only)
# DEV_RELOAD=1
